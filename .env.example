# ============================================================
#  Kaysan AI 🧠  —  پیکربندی
# ============================================================
#  ⚠️ این کلیدها تو چت لو رفتن. قبل از عمومی‌کردن:
#     - توکن بات: تو BotFather دستور /revoke
#     - کلید OpenRouter: تو openrouter.ai کلید جدید بساز
# ------------------------------------------------------------

# توکن بات (BotFather)
BOT_TOKEN=PUT-TOKEN

# کلید OpenRouter
OPENROUTER_KEY=PUT-KEY

# آیدی عددی خودت (سازنده). با @userinfobot پیداش کن.
OWNER_ID=0
# یوزرنیم خودت برای ارجاع کاربر بعد از محدودیت (بدون @)
OWNER_USERNAME=ashkan_surii

# زبان پیش‌فرض: ku | fa | en
DEFAULT_LANG=ku

# محدودیت پیام رایگان قبل از اشتراک
FREE_MESSAGE_LIMIT=100

# ----- Local Bot API Server (اختیاری) -----
# اگر سرور لوکال راه انداختی آدرسش را بگذار، وگرنه خالی.
BOT_API_BASE_URL=

# ----- Groq (برای Whisper STT — رایگان و دقیق) -----
# کلید رایگان از https://console.groq.com بگیر
GROQ_API_KEY=

DOWNLOAD_DIR=/tmp/kaysan

# دکمه‌های رنگی (Bot API 9.4+)
USE_COLORED_BUTTONS=true

# ============================================================
#  مدل‌ها — زنجیره‌ی fallback (با کاما جدا کن).
#  ⚠️ اسلاگ مدل‌ها هفتگی عوض می‌شن. روی openrouter.ai/models چک کن.
#  اگر یکی کار نکرد، بات خودکار سراغ بعدی می‌رود.
# ============================================================

# مغزِ روتر (تصمیم می‌گیرد هر درخواست به کدام مدل برود)
ROUTER_MODELS=openai/gpt-oss-120b:free,openrouter/free

# چت عمومی + فارسی/کوردی (چندزبانه)
CHAT_MODELS=google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free,openrouter/free

# کدنویسی
CODE_MODELS=qwen/qwen3-coder:free,openai/gpt-oss-120b:free,openrouter/free

# استدلال/ریاضی
REASON_MODELS=deepseek/deepseek-r1:free,openai/gpt-oss-120b:free,openrouter/free

# کانتکست طولانی (سند بزرگ)
LONG_MODELS=meta-llama/llama-4-maverick:free,google/gemma-4-31b-it:free

# درک تصویر (vision)
VISION_MODELS=google/gemma-4-31b-it:free,nvidia/nemotron-3-nano-omni:free

# درک صدا/ویس (audio input)
AUDIO_MODELS=nvidia/nemotron-3-nano-omni:free

# ----- ساخت عکس -----
# اگر خالی باشد از Pollinations (رایگان، بدون کلید) استفاده می‌شود.
# اگر مدل تصویرسازِ OpenRouter داری، اسلاگش را اینجا بگذار.
IMAGE_MODEL=
